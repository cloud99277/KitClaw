#!/usr/bin/env bash
# pre-commit hook: 校验 staged Markdown 文件的 frontmatter
# 安装方法: bash src/hooks/install.sh

set -euo pipefail

# 获取项目根目录
REPO_ROOT=$(git rev-parse --show-toplevel)
VALIDATOR="$REPO_ROOT/src/hooks/validate_frontmatter.py"

# 获取 staged 的知识库 Markdown 文件（README 等外部展示文档不强制 frontmatter）
mapfile -t MD_FILES < <(
    git diff --cached --name-only --diff-filter=ACM \
    | grep -E '^(docs|skills)/.*\.(md|markdown)$' || true
)

if [ ${#MD_FILES[@]} -eq 0 ]; then
    # 没有 staged 的 Markdown 文件，直接通过
    exit 0
fi

echo "🔍 Frontmatter validation..."

# 确定 Python 路径（优先用 venv）
if [ -f "$REPO_ROOT/.venv/bin/python3" ]; then
    PYTHON="$REPO_ROOT/.venv/bin/python3"
else
    PYTHON="python3"
fi

# 运行校验
"$PYTHON" "$VALIDATOR" "${MD_FILES[@]}"
exit_code=$?

if [ $exit_code -ne 0 ]; then
    echo ""
    echo "❌ Commit blocked: frontmatter validation failed."
    echo "   Fix the errors above and try again."
    echo "   To skip: git commit --no-verify"
fi

exit $exit_code
